# Keep the build context small and secret-free.

# Secrets and local env
.env
.env.*
!.env.example

# Python venvs and caches (the image builds its own)
mcp/.venv/
.venv/
**/__pycache__/
*.pyc
.pytest_cache/

# VCS and editor
.git/
.gitignore
.vscode/
.idea/
.DS_Store

# Benchmark run outputs and scratch (regenerated, not part of the image)
benchmark/runs/
**/*.rds
scratchpad/

# The model is never baked in
hf-cache/
data/

# Private research / dev files: not part of the product image (mirror the gitignore
# private set). These are root-relative, so the PUBLIC mcp/docs/CLAUDE.md shim is kept.
CLAUDE.md
PLANNING.md
PREP_AUTO_DESIGN.md
CONCEPTS.md
CONTRACT.md
TECH_NOTES.*
ref.md
run_tests.sh
publish.sh
benchmark/
manual/
.claude/
supp_docs/
