# BRIER-Agent deployment settings. Copy to .env and edit:  cp .env.example .env
# .env is gitignored (it holds secrets). NEVER commit a real API key.

# --- Which model backend? Pick ONE block. ------------------------------------------

# (A) LOCAL model via the vLLM service (docker compose --profile local up).
#     Nothing leaves the machine. Needs an NVIDIA GPU. These are the compose defaults,
#     so for the local path you can leave every line below commented out.
# BRIER_MODEL_ENDPOINT=http://vllm:8000/v1
# BRIER_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# BRIER_API_KEY=EMPTY
# BRIER_DEPLOYMENT_MODE=local

# (B) EXTERNAL API (no GPU). Tool RESULTS (variant ids, sample counts, summary stats,
#     metrics) go to the provider; raw genotypes never do. Set all four.
# BRIER_MODEL_ENDPOINT=https://api.openai.com/v1
# BRIER_MODEL_NAME=gpt-4o-mini
# BRIER_API_KEY=sk-...your-key...
# BRIER_DEPLOYMENT_MODE=external

# --- Data + build ------------------------------------------------------------------

# Host directory holding the user's data, mounted read-only at /data in the container.
BRIER_DATA_DIR=./data

# Pin a BRIER commit for a reproducible image (default tracks the branch).
# BRIER_REF=main

# Where vLLM caches downloaded weights on the host (local profile only).
# HF_CACHE_DIR=./hf-cache
